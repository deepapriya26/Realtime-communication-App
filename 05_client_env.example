# SyncSpace Client Environment Variables
# Copy this to .env and fill in your values

# Backend server URL (for Socket.io and API calls)
REACT_APP_SERVER_URL=http://localhost:5000

# STUN/TURN servers for WebRTC NAT traversal
# Free STUN servers (use Twilio/Xirsys TURN servers in production)
REACT_APP_STUN_SERVER=stun:stun.l.google.com:19302
REACT_APP_STUN_SERVER_2=stun:stun1.l.google.com:19302

# Optional TURN server (required for users behind strict NAT/firewalls)
# REACT_APP_TURN_URL=turn:your.turn.server:3478
# REACT_APP_TURN_USERNAME=your_turn_username
# REACT_APP_TURN_CREDENTIAL=your_turn_credential
